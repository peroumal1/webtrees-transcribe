/**
 * @var \Fisharebest\Webtrees\Individual                    $individual
 * @var \Peroumal1\WebtreesTranscribe\TranscribeModule      $module
 * @var bool                                                $api_key_set
 * @var string                                              $route_url
 * @var string                                              $add_fact_url
 */
?>

<div class="wt-transcribe-tab p-3">
    <?php if (!$api_key_set): ?>
        <div class="alert alert-warning">
            <?= I18N::translate('The Transcribe module requires an Anthropic API key. Please configure it in the module settings.') ?>
        </div>
    <?php else: ?>
        <p class="text-muted small">
            <?= I18N::translate('Upload a scanned document (image or PDF) to extract names, dates, and places using Claude AI.') ?>
        </p>

        <form id="wt-transcribe-form" enctype="multipart/form-data">
            <?= csrf_field() ?>

            <div class="mb-3">
                <label for="wt-transcribe-file" class="form-label">
                    <?= I18N::translate('Document image') ?>
                </label>
                <input
                    type="file"
                    id="wt-transcribe-file"
                    name="document"
                    class="form-control"
                    accept="image/jpeg,image/png,image/webp,image/gif"
                    required
                >
            </div>

            <button type="submit" id="wt-transcribe-submit" class="btn btn-primary">
                <?= I18N::translate('Transcribe') ?>
            </button>
        </form>

        <div id="wt-transcribe-loading" class="mt-3 d-none">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            <?= I18N::translate('Transcribing document…') ?>
        </div>

        <div id="wt-transcribe-error" class="alert alert-danger mt-3 d-none"></div>

        <div id="wt-transcribe-result" class="mt-4 d-none">
            <h6><?= I18N::translate('Transcription') ?></h6>
            <pre id="wt-transcribe-text" class="bg-light p-3 rounded small" style="white-space: pre-wrap;"></pre>

            <div class="row mt-3">
                <div class="col-md-6">
                    <h6><?= I18N::translate('Names found') ?></h6>
                    <ul id="wt-transcribe-names" class="small"></ul>
                </div>
                <div class="col-md-6">
                    <h6><?= I18N::translate('Dates found') ?></h6>
                    <ul id="wt-transcribe-dates" class="small"></ul>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <h6><?= I18N::translate('Places found') ?></h6>
                    <ul id="wt-transcribe-places" class="small"></ul>
                </div>
                <div class="col-md-6">
                    <h6><?= I18N::translate('Relationships') ?></h6>
                    <ul id="wt-transcribe-relationships" class="small"></ul>
                </div>
            </div>

            <hr>
            <h6><?= I18N::translate('Add fact to this record') ?></h6>
            <div id="wt-add-fact-success" class="alert alert-success d-none"></div>
            <div id="wt-add-fact-error" class="alert alert-danger d-none"></div>

            <form id="wt-add-fact-form" class="row g-2 align-items-end">
                <?= csrf_field() ?>
                <div class="col-md-3">
                    <label class="form-label small"><?= I18N::translate('Fact type') ?></label>
                    <select name="fact_type" class="form-select form-select-sm">
                        <option value="BIRT"><?= I18N::translate('Birth') ?></option>
                        <option value="BAPM"><?= I18N::translate('Baptism') ?></option>
                        <option value="DEAT"><?= I18N::translate('Death') ?></option>
                        <option value="BURI"><?= I18N::translate('Burial') ?></option>
                        <option value="MARR"><?= I18N::translate('Marriage') ?></option>
                        <option value="RESI"><?= I18N::translate('Residence') ?></option>
                        <option value="EMIG"><?= I18N::translate('Emigration') ?></option>
                        <option value="IMMI"><?= I18N::translate('Immigration') ?></option>
                        <option value="NATU"><?= I18N::translate('Naturalization') ?></option>
                        <option value="CENS"><?= I18N::translate('Census') ?></option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small"><?= I18N::translate('Date') ?></label>
                    <input type="text" id="wt-fact-date" name="date" class="form-control form-control-sm" placeholder="14 DEC 1895">
                </div>
                <div class="col-md-4">
                    <label class="form-label small"><?= I18N::translate('Place') ?></label>
                    <input type="text" id="wt-fact-place" name="place" class="form-control form-control-sm" placeholder="Sandringham, Norfolk, England">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success btn-sm w-100"><?= I18N::translate('Add') ?></button>
                </div>
            </form>
        </div>

        <script>
        (function () {
            const transcribeUrl = <?= json_encode($route_url) ?>;
            const addFactUrl    = <?= json_encode($add_fact_url) ?>;

            document.getElementById('wt-transcribe-form').addEventListener('submit', async function (e) {
                e.preventDefault();

                const loading = document.getElementById('wt-transcribe-loading');
                const error   = document.getElementById('wt-transcribe-error');
                const result  = document.getElementById('wt-transcribe-result');
                const submit  = document.getElementById('wt-transcribe-submit');

                loading.classList.remove('d-none');
                error.classList.add('d-none');
                result.classList.add('d-none');
                submit.disabled = true;

                try {
                    const res  = await fetch(transcribeUrl, { method: 'POST', body: new FormData(e.target) });
                    const data = await res.json();

                    if (!res.ok || data.error) {
                        error.textContent = data.error || 'An unexpected error occurred.';
                        error.classList.remove('d-none');
                        return;
                    }

                    document.getElementById('wt-transcribe-text').textContent = data.transcription ?? '';
                    renderList('wt-transcribe-names', data.names);
                    renderList('wt-transcribe-dates', data.dates);
                    renderList('wt-transcribe-places', data.places);
                    renderList('wt-transcribe-relationships', data.relationships);

                    // Pre-fill the add-fact form with first extracted date and place
                    if (data.dates && data.dates.length > 0) {
                        document.getElementById('wt-fact-date').value = data.dates[0];
                    }
                    if (data.places && data.places.length > 0) {
                        document.getElementById('wt-fact-place').value = data.places[0];
                    }

                    result.classList.remove('d-none');
                } catch (err) {
                    error.textContent = 'Network error. Please try again.';
                    error.classList.remove('d-none');
                } finally {
                    loading.classList.add('d-none');
                    submit.disabled = false;
                }
            });

            document.getElementById('wt-add-fact-form').addEventListener('submit', async function (e) {
                e.preventDefault();

                const successEl = document.getElementById('wt-add-fact-success');
                const errorEl   = document.getElementById('wt-add-fact-error');
                const btn       = e.target.querySelector('button[type=submit]');

                successEl.classList.add('d-none');
                errorEl.classList.add('d-none');
                btn.disabled = true;

                try {
                    const body = new FormData(e.target);
                    const res  = await fetch(addFactUrl, { method: 'POST', body });
                    const text = await res.text();
                    let data;
                    try { data = JSON.parse(text); } catch (_) { data = { error: text.substring(0, 200) }; }

                    if (!res.ok || data.error) {
                        errorEl.textContent = data.error || 'Could not add fact.';
                        errorEl.classList.remove('d-none');
                    } else {
                        successEl.textContent = 'Fact added — reload the page to see it in the pending changes.';
                        successEl.classList.remove('d-none');
                    }
                } catch (err) {
                    errorEl.textContent = 'Network error: ' + err.message;
                    errorEl.classList.remove('d-none');
                } finally {
                    btn.disabled = false;
                }
            });

            function renderList(id, items) {
                const el = document.getElementById(id);
                el.innerHTML = '';
                (items ?? []).forEach(item => {
                    const li = document.createElement('li');
                    li.textContent = item;
                    el.appendChild(li);
                });
            }
        })();
        </script>
    <?php endif; ?>
</div>
